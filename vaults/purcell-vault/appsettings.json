{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // BUG-0002: Hardcoded SA credentials in config file (CWE-798, CVSS 9.8, CRITICAL, Tier 1)
    "VaultDb": "Server=db-server;Database=PurcellVault;User Id=sa;Password=Vault$uper$ecret2024!;TrustServerCertificate=True;Encrypt=False"
  },
  "Jwt": {
    // BUG-0003: Weak JWT signing key — only 8 characters, trivially brute-forceable (CWE-326, CVSS 9.1, CRITICAL, Tier 1)
    "Key": "PV$ecr3t",
    "Issuer": "PurcellVault",
    "Audience": "PurcellVaultUsers",
    // BUG-0004: Excessive token lifetime of 30 days (CWE-613, CVSS 5.4, MEDIUM, Tier 2)
    "ExpirationDays": 30
  },
  "Encryption": {
    // BUG-0005: Static IV stored in config — IV reuse destroys AES-CBC confidentiality (CWE-329, CVSS 7.5, HIGH, Tier 1)
    "StaticIV": "1234567890abcdef",
    // BUG-0006: Encryption key in plaintext config, committed to repo (CWE-312, CVSS 9.0, CRITICAL, Tier 1)
    "MasterKey": "ThisIsA32ByteKeyForAES256Encrypt"
  },
  "Cors": {
    // BUG-0007: Wildcard CORS origin allows any domain (CWE-942, CVSS 5.3, MEDIUM, Tier 2)
    "AllowedOrigins": [ "*" ]
  },
  // BUG-0008: Debug mode left enabled in production config (CWE-489, CVSS 3.6, LOW, Tier 3)
  "DetailedErrors": true,
  "AdminApiKey": "admin-api-key-12345"
}
