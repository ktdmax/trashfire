rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // BUG-0002: Wildcard match allows read/write to ALL collections — no per-collection access control (CWE-732, CVSS 9.8, CRITICAL, Tier 1)
    match /{document=**} {
      allow read: if true;
      // BUG-0009: Write access granted to any authenticated user on any document — no ownership or role checks (CWE-863, CVSS 9.1, CRITICAL, Tier 1)
      allow write: if request.auth != null;
    }

    // Users collection
    match /users/{userId} {
      // BUG-0034: Any authenticated user can read any other user's profile document (CWE-639, CVSS 6.5, HIGH, Tier 2)
      allow read: if request.auth != null;
      // BUG-0058: User can write to own document but no field-level validation — can set isAdmin, isPremium, etc. (CWE-915, CVSS 8.1, CRITICAL, Tier 1)
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Articles collection
    match /articles/{articleId} {
      allow read: if true;
      // BUG-0064: Any authenticated user can create/modify articles — no admin role check (CWE-862, CVSS 7.5, HIGH, Tier 2)
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      // BUG-0077: Article deletion allowed for any authenticated user — no ownership validation (CWE-639, CVSS 7.5, CRITICAL, Tier 1)
      allow delete: if request.auth != null;
    }

    // Comments subcollection
    match /articles/{articleId}/comments/{commentId} {
      allow read: if true;
      // BUG-0081: Comment creation doesn't validate that request.auth.uid matches the comment's author field — impersonation possible (CWE-290, CVSS 6.5, TRICKY, Tier 6)
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // User bookmarks (server-synced)
    match /user_bookmarks/{userId}/{bookmarkId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Push notification tokens
    match /fcm_tokens/{tokenId} {
      // BUG-0082: FCM tokens readable by any authenticated user — allows sending targeted push notifications to other users (CWE-200, CVSS 5.4, TRICKY, Tier 6)
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // App configuration
    match /config/{configId} {
      // BUG-0092: App config documents writable by any authenticated user — can modify feature flags, API endpoints, etc. (CWE-732, CVSS 8.1, CRITICAL, Tier 1)
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Analytics events
    match /analytics/{eventId} {
      allow read: if false;
      allow create: if request.auth != null;
      // BUG-0099: No rate limiting on analytics writes — DoS via flooding Firestore with events (CWE-770, CVSS 5.3, MEDIUM, Tier 3)
      // Also no size validation on analytics event documents
    }

    // Reported articles
    match /reports/{reportId} {
      // BUG-0032: Reports collection readable by all authenticated users — reporter identity and report content exposed (CWE-200, CVSS 4.3, MEDIUM, Tier 3)
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['article_url', 'reason'])
        && request.resource.data.reason is string;
      allow update, delete: if false;
    }
  }
}
