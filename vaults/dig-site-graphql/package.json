{
  "name": "dig-site-graphql",
  "version": "1.0.0",
  "description": "Museum collection management system - Apollo Server GraphQL API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:run": "typeorm migration:run -d src/config.ts",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "typeorm": "^0.3.20",
    "pg": "^8.11.3",
    "dataloader": "^2.2.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.4.1",
    "graphql-depth-limit": "^1.1.0",
    "uuid": "^9.0.0",
    "node-fetch": "^2.7.0",
    "xml2js": "^0.6.2",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "@types/lodash": "^4.17.0",
    "@types/uuid": "^9.0.7"
  }
}
