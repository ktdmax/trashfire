<div class="container mx-auto px-4 py-8">
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <!-- Employee Header -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-6 py-8 text-white">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold"><%= @employee.full_name %></h1>
          <p class="text-blue-200 mt-1"><%= @employee.title %> &mdash; <%= @employee.department %></p>
          <p class="text-blue-300 text-sm">ID: <%== @employee.employee_id %></p>
        </div>
        <div class="text-right">
          <span class="px-3 py-1 rounded-full text-sm font-medium
            <%= @employee.status == 'active' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
            <%= @employee.status&.capitalize %>
          </span>
        </div>
      </div>
    </div>

    <!-- Employee Details -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-6">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-gray-800">Personal Information</h2>

        <div class="border rounded-lg p-4 space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-600">Email:</span>
            <span class="font-medium"><%= @employee.user&.email %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Phone:</span>
            <span class="font-medium"><%= @employee.phone %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">SSN:</span>
            <span class="font-medium"><%= @employee.ssn %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Start Date:</span>
            <span class="font-medium"><%= @employee.start_date&.strftime("%B %d, %Y") %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Years of Service:</span>
            <span class="font-medium"><%= @employee.years_of_service %></span>
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-gray-800">Employment Details</h2>

        <div class="border rounded-lg p-4 space-y-3">
          <div class="flex justify-between">
            <span class="text-gray-600">Department:</span>
            <span class="font-medium"><%= @employee.department %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Title:</span>
            <span class="font-medium"><%= @employee.title %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Salary:</span>
            <span class="font-medium"><%= number_to_currency(@employee.salary) %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Manager:</span>
            <span class="font-medium">
              <% if @employee.manager %>
                <%= link_to @employee.manager.full_name, employee_path(@employee.manager) %>
              <% else %>
                <span class="text-gray-400">None</span>
              <% end %>
            </span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-600">Role:</span>
            <span class="font-medium"><%= @employee.user&.role&.humanize %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Notes Section -->
    <% if @employee.notes.present? %>
      <div class="p-6 border-t">
        <h2 class="text-xl font-semibold text-gray-800 mb-4">Notes</h2>
        <div class="prose max-w-none">
          <%= @employee.notes.html_safe %>
        </div>
      </div>
    <% end %>

    <!-- Performance Reviews -->
    <div class="p-6 border-t">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Performance Reviews</h2>
      <% if @employee.performance_reviews.any? %>
        <div class="space-y-4">
          <% @employee.performance_reviews.each do |review| %>
            <div class="border rounded-lg p-4">
              <div class="flex justify-between items-start">
                <div>
                  <h3 class="font-medium"><%= review.title %></h3>
                  <p class="text-sm text-gray-500"><%= review.review_date&.strftime("%B %Y") %></p>
                </div>
                <span class="px-2 py-1 rounded text-sm
                  <%= review.rating.to_i >= 4 ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                  Rating: <%= review.rating %>/5
                </span>
              </div>
              <!-- BUG-0092 referenced: review content rendered unsanitized -->
              <div class="mt-3 text-gray-700">
                <%== review.content %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No performance reviews yet.</p>
      <% end %>
    </div>

    <!-- PTO Summary -->
    <div class="p-6 border-t">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">PTO Balance</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <% %w[vacation sick personal bereavement parental].each do |type| %>
          <div class="border rounded-lg p-3 text-center">
            <p class="text-sm text-gray-500"><%= type.capitalize %></p>
            <p class="text-2xl font-bold text-blue-600">
              <%= @employee.pto_balances&.dig(type) || 0 %>
            </p>
            <p class="text-xs text-gray-400">days remaining</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Recent Documents -->
    <div class="p-6 border-t">
      <h2 class="text-xl font-semibold text-gray-800 mb-4">Documents</h2>
      <% if @employee.documents.any? %>
        <table class="w-full">
          <thead>
            <tr class="text-left text-sm text-gray-500 border-b">
              <th class="pb-2">Title</th>
              <th class="pb-2">Category</th>
              <th class="pb-2">Uploaded</th>
              <th class="pb-2">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @employee.documents.order(created_at: :desc).limit(10).each do |doc| %>
              <tr class="border-b">
                <td class="py-2"><%= doc.title %></td>
                <td class="py-2"><%= doc.category&.humanize %></td>
                <td class="py-2"><%= doc.created_at&.strftime("%m/%d/%Y") %></td>
                <td class="py-2">
                  <%= link_to "Download", download_document_path(doc), class: "text-blue-600 hover:underline" %>
                  <%= link_to "Preview", preview_document_path(doc), class: "text-blue-600 hover:underline ml-2" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-gray-500 italic">No documents uploaded.</p>
      <% end %>
    </div>

    <!-- Actions -->
    <div class="p-6 border-t bg-gray-50">
      <div class="flex flex-wrap gap-3">
        <%= link_to "Edit", edit_employee_path(@employee), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
        <%= link_to "New PTO Request", new_pto_request_path(employee_id: @employee.id), class: "bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700" %>
        <%= link_to "Upload Document", new_document_path(employee_id: @employee.id), class: "bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700" %>

        <% if current_user&.manager? || current_user&.hr_admin? || current_user&.super_admin? %>
          <!-- BUG-0088 referenced: salary update form available to managers, but endpoint has no auth -->
          <div class="ml-auto">
            <%= form_tag update_salary_employee_path(@employee), method: :patch, class: "inline-flex items-center gap-2" do %>
              <%= number_field_tag :salary, @employee.salary, class: "border rounded px-2 py-1 w-32", step: 1000 %>
              <%= submit_tag "Update Salary", class: "bg-yellow-600 text-white px-4 py-2 rounded hover:bg-yellow-700 cursor-pointer" %>
            <% end %>

            <%= link_to "Promote", promote_employee_path(@employee), method: :post,
                data: { confirm: "Promote this employee?" },
                class: "bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>

            <%= link_to "Terminate", terminate_employee_path(@employee), method: :post,
                data: { confirm: "Are you sure you want to terminate this employee?" },
                class: "bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Org Chart Position -->
  <div class="mt-8 bg-white shadow rounded-lg p-6">
    <h2 class="text-xl font-semibold text-gray-800 mb-4">Organization</h2>
    <div class="flex flex-col items-center">
      <% if @employee.manager %>
        <div class="border rounded-lg p-3 bg-gray-50 mb-2">
          <%= link_to @employee.manager.full_name, employee_path(@employee.manager), class: "text-blue-600" %>
          <span class="text-sm text-gray-500">(<%= @employee.manager.title %>)</span>
        </div>
        <div class="w-px h-6 bg-gray-300"></div>
      <% end %>

      <div class="border-2 border-blue-500 rounded-lg p-3 bg-blue-50">
        <strong><%= @employee.full_name %></strong>
        <span class="text-sm text-gray-500">(<%= @employee.title %>)</span>
      </div>

      <% if @employee.direct_reports.any? %>
        <div class="w-px h-6 bg-gray-300"></div>
        <div class="flex flex-wrap gap-4 justify-center">
          <% @employee.direct_reports.each do |report| %>
            <div class="border rounded-lg p-3 bg-gray-50">
              <%= link_to report.full_name, employee_path(report), class: "text-blue-600" %>
              <span class="text-sm text-gray-500">(<%= report.title %>)</span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
