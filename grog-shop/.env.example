# ============================================================
# Grog Shop Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/grogshop"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-string"

# JWT (used for custom token generation)
# BUG-028 reference: If this is unset, a weak hardcoded fallback is used in lib/auth.ts
JWT_SECRET="change-this-to-a-random-string"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_key_here"
STRIPE_PUBLISHABLE_KEY="pk_test_your_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="Your Store <noreply@example.com>"

# App
NEXT_PUBLIC_URL="http://localhost:3000"
BACKEND_URL="http://localhost:4000"
NODE_ENV="development"
